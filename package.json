{
  "name": "sutrapad",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "cert:dev": "node scripts/create-dev-cert.mjs",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.vitest.json",
    "lint": "oxlint src tests --deny-warnings",
    "lint:fix": "oxlint src tests --fix --deny-warnings",
    "check": "npm run lint && npm run test && npm run build",
    "test": "npm run typecheck && vitest run",
    "test:smoke": "vitest run tests/create-app-smoke.test.ts",
    "test:unit": "vitest run --exclude tests/create-app-smoke.test.ts",
    "test:coverage": "npm run typecheck && vitest run --coverage",
    "test:watch": "vitest",
    "test:mutation": "stryker run",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.9.0",
    "@vitest/coverage-istanbul": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.8",
    "fontaine": "^0.8.0",
    "happy-dom": "^20.9.0",
    "oxlint": "^1.65.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
