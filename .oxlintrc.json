{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn", "oxc", "vitest", "promise"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "pedantic": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "warn"
  },
  "env": {
    "browser": true,
    "es2022": true
  },
  "globals": {
    "google": "readonly",
    "__APP_VERSION__": "readonly",
    "__APP_BUILD_TIME__": "readonly",
    "__APP_COMMIT_HASH__": "readonly"
  },
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-debugger": "error",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "complexity": ["warn", { "max": 22, "variant": "classic" }],
    "max-depth": ["warn", { "max": 4 }],
    "max-lines-per-function": [
      "warn",
      { "max": 350, "skipBlankLines": true, "skipComments": true }
    ],
    "max-nested-callbacks": ["warn", { "max": 3 }],
    "max-params": ["warn", { "max": 5 }],
    "typescript/no-explicit-any": "warn",
    "typescript/no-non-null-assertion": "warn",
    "typescript/consistent-type-imports": "warn",
    "unicorn/prefer-node-protocol": "error",
    "unicorn/no-array-for-each": "off",
    "unicorn/prefer-dom-node-dataset": "warn",
    "unicorn/prefer-string-replace-all": "warn",
    "accessor-pairs": "warn",
    "no-promise-executor-return": "warn",
    "require-await": "warn",
    "require-unicode-regexp": "warn",
    "unicorn/escape-case": "warn",
    "unicorn/prefer-dom-node-append": "warn",
    "unicorn/no-array-callback-reference": "warn",
    "no-loop-func": "warn",
    "unicorn/prefer-at": "warn",
    "unicorn/prefer-dom-node-remove": "warn",
    "no-redeclare": ["warn", { "builtinGlobals": false }],
    "unicorn/prefer-code-point": "warn",
    "vitest/expect-expect": ["warn", { "assertFunctionNames": ["expect", "ensureNonEmpty"] }],
    "vitest/valid-expect": "warn",
    "vitest/no-conditional-expect": "warn",
    "vitest/require-to-throw-message": "warn",
    "vitest/no-focused-tests": "error",
    "vitest/no-disabled-tests": "warn",
    "vitest/no-identical-title": "warn",
    "vitest/no-commented-out-tests": "warn",
    "vitest/no-test-return-statement": "warn",
    "vitest/require-mock-type-parameters": "off",
    "promise/always-return": "warn",
    "import/no-unassigned-import": "off",
    "no-underscore-dangle": [
      "warn",
      { "allow": ["__APP_VERSION__", "__APP_BUILD_TIME__", "__APP_COMMIT_HASH__"] }
    ],
    "import/no-duplicates": "error"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "reports/**",
    "public/**"
  ]
}
